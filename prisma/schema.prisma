generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// --- ROLES ---
model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique // e.g., "ADMIN", "READER"
  users User[]

  @@map("roles")
}

model User{
  id Int @id @default(autoincrement())
  name String? 
  email String @unique 
  password String 
  roleId Int
  role Role @relation(fields: [roleId], references: [id])

  favorites Work[] @relation("UserFavorites") //relacion muchos a muchos

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// autores
model Author{
  id Int @id @default(autoincrement())
  name String

  works Work[]

   @@map("authors")
}

// generos
model Genre{
  id Int @id @default(autoincrement())
  name String
  works Work[] @relation("WorkGenres")
  @@map("genres")
}
// obras
model Work{
  id Int @id @default(autoincrement())
  title String
  descripction String
  coverUrl String?
  publishYear Int?

  authorId Int
  author Author @relation(fields: [authorId],references: [id])

  genres Genre[]  @relation("WorkGenres")
  favoritedBy User[]   @relation("UserFavorites")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("works")
}