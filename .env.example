# Variables de entorno para la Base de Datos (MySQL/MariaDB)
# Reemplaza 'usuario', 'password', y 'localhost:3306' por tu configuración real.
DATABASE_URL="mysql://usuario:password@localhost:3306/comic_catalog_db"
DATABASE_USER="usuario"
DATABASE_PASSWORD="password"
DATABASE_NAME="comic_catalog_db"
DATABASE_HOST="localhost"
DATABASE_PORT=3306

# Puerto del servidor (opcional, por defecto es 3000)
PORT=3000

# Better Auth - Configuración de Autenticación
# Secreto seguro para firmar las cookies de sesión (Debe tener alta entropía y mínimo 32 caracteres)
# Generar uno nuevo para producción con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET="tu_secreto_super_seguro_aqui_generado_con_crypto"

# URL base del servidor (Requerido por Better Auth para callbacks y redirecciones)
BETTER_AUTH_URL="http://localhost:3000"